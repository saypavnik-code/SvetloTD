// ─────────────────────────────────────────────────────────────────────────────

export interface Waypoint {
  x: number;
  y: number;
}

const T = 40; // TILE_SIZE — avoid importing to keep data files pure
const cx = (col: number) => col * T + T / 2;
const cy = (row: number) => row * T + T / 2;

